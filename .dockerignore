# =============================================================================
# Docker Ignore - Exclude unnecessary files from Docker build context
# =============================================================================

# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git/
.gitignore
.github/

# -----------------------------------------------------------------------------
# Build Artifacts (Rust)
# -----------------------------------------------------------------------------
# Exclude local target directory (builds happen in container)
target/

# Keep Cargo.lock for reproducible builds (don't exclude)

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.env
!.env.example

# -----------------------------------------------------------------------------
# Certificates and Keys
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Data Directories
# -----------------------------------------------------------------------------
data/
logs/

# -----------------------------------------------------------------------------
# Docker Files (not needed in build context)
# -----------------------------------------------------------------------------
docker-compose/
docker-compose.yaml
docker-compose.yml
.dockerignore
Dockerfile*

# Keep only the specific Dockerfile being built:
!Dockerfile.scred-proxy
!Dockerfile.scred-mitm

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs/
*.md
!README.md

# -----------------------------------------------------------------------------
# Scripts and Tools
# -----------------------------------------------------------------------------
scripts/
.pi/
*.sh

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# -----------------------------------------------------------------------------
# Test and Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.profraw
*.profdata

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
.profile_result
