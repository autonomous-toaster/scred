//! TDD Tests for Phase 1: RedactionEngine Selector Support
//!
//! Tests for adding selector-aware redaction to RedactionEngine.
//! Written BEFORE implementation (TDD approach).

#[cfg(test)]
mod phase1_redaction_engine_selector_tests {
    use scred_redactor::RedactionEngine;
    use scred_redactor::{PatternSelector, PatternTier};

    // =========================================================================
    // CORE FUNCTIONALITY: Engine with Selector Support
    // =========================================================================

    #[test]
    fn test_redaction_engine_new_has_no_selector() {
        let engine = RedactionEngine::new(Default::default());
        // Default engine should not have selector (backward compatible)
        // After Phase 1, we'll add methods to check for selector
    }

    #[test]
    fn test_redaction_engine_with_selector_basic() {
        // Phase 1 will add `with_selector()` method
        let selector = PatternSelector::Tiers(vec![PatternTier::Critical]);
        let engine = RedactionEngine::with_selector(Default::default(), selector);
        
        // Verify selector is stored
        assert!(engine.has_selector());
    }

    #[test]
    fn test_selector_tier_critical() {
        let selector = PatternSelector::Tiers(vec![PatternTier::Critical]);
        let engine = RedactionEngine::with_selector(Default::default(), selector.clone());
        
        match engine.get_selector() {
            Some(sel) => {
                if let PatternSelector::Tiers(tiers) = sel {
                    assert_eq!(tiers.len(), 1);
                    assert!(tiers.contains(&PatternTier::Critical));
                } else {
                    panic!("Expected Tier selector");
                }
            }
            None => panic!("Expected selector to be present"),
        }
    }

    #[test]
    fn test_selector_tier_multiple() {
        let selector = PatternSelector::Tiers(vec![
            PatternTier::Critical,
            PatternTier::ApiKeys,
            PatternTier::Infrastructure,
        ]);
        let engine = RedactionEngine::with_selector(Default::default(), selector);
        
        match engine.get_selector() {
            Some(PatternSelector::Tiers(tiers)) => {
                assert_eq!(tiers.len(), 3);
                assert!(tiers.contains(&PatternTier::Critical));
                assert!(tiers.contains(&PatternTier::ApiKeys));
                assert!(tiers.contains(&PatternTier::Infrastructure));
            }
            _ => panic!("Expected Tier selector with 3 tiers"),
        }
    }

    #[test]
    fn test_selector_all() {
        let selector = PatternSelector::All;
        let engine = RedactionEngine::with_selector(Default::default(), selector);
        
        match engine.get_selector() {
            Some(PatternSelector::All) => {}, // Success
            _ => panic!("Expected All selector"),
        }
    }

    #[test]
    fn test_selector_none() {
        let selector = PatternSelector::None;
        let engine = RedactionEngine::with_selector(Default::default(), selector);
        
        match engine.get_selector() {
            Some(PatternSelector::None) => {}, // Success
            _ => panic!("Expected None selector"),
        }
    }

    // =========================================================================
    // SELECTOR STORAGE & RETRIEVAL
    // =========================================================================

    #[test]
    fn test_selector_is_cloned_and_stored() {
        let selector = PatternSelector::Tiers(vec![PatternTier::ApiKeys]);
        let engine = RedactionEngine::with_selector(Default::default(), selector.clone());
        
        // Verify we can retrieve it
        let stored = engine.get_selector().expect("Selector should exist");
        match stored {
            PatternSelector::Tiers(tiers) => {
                assert_eq!(tiers.len(), 1);
                assert_eq!(tiers[0], PatternTier::ApiKeys);
            }
            _ => panic!("Expected Tier selector"),
        }
    }

    #[test]
    fn test_multiple_engines_independent_selectors() {
        let sel1 = PatternSelector::Tiers(vec![PatternTier::Critical]);
        let sel2 = PatternSelector::Tiers(vec![PatternTier::Services]);
        
        let engine1 = RedactionEngine::with_selector(Default::default(), sel1);
        let engine2 = RedactionEngine::with_selector(Default::default(), sel2);
        
        // Verify they maintain independent selectors
        match engine1.get_selector() {
            Some(PatternSelector::Tiers(tiers)) => {
                assert!(tiers.contains(&PatternTier::Critical));
            }
            _ => panic!("Engine1 failed"),
        }
        
        match engine2.get_selector() {
            Some(PatternSelector::Tiers(tiers)) => {
                assert!(tiers.contains(&PatternTier::Services));
            }
            _ => panic!("Engine2 failed"),
        }
    }

    // =========================================================================
    // METHOD SIGNATURES (TDD: these methods will be added)
    // =========================================================================

    #[test]
    #[ignore = "Implementation note: Phase 1 adds these methods"]
    fn phase1_todo_method_with_selector() {
        // After Phase 1, RedactionEngine will have:
        // pub fn with_selector(config: RedactionConfig, selector: PatternSelector) -> Self { ... }
    }

    #[test]
    #[ignore = "Implementation note: Phase 1 adds these methods"]
    fn phase1_todo_method_has_selector() {
        // After Phase 1, RedactionEngine will have:
        // pub fn has_selector(&self) -> bool { ... }
    }

    #[test]
    #[ignore = "Implementation note: Phase 1 adds these methods"]
    fn phase1_todo_method_get_selector() {
        // After Phase 1, RedactionEngine will have:
        // pub fn get_selector(&self) -> Option<&PatternSelector> { ... }
    }

    #[test]
    #[ignore = "Implementation note: Phase 1 adds these methods"]
    fn phase1_todo_method_redact_with_selector() {
        // After Phase 1, RedactionEngine will have:
        // pub fn redact_with_selector(&self, text: &str) -> RedactionResult { ... }
        // This method will respect the selector when filtering patterns
    }

    // =========================================================================
    // BACKWARD COMPATIBILITY
    // =========================================================================

    #[test]
    fn test_existing_redact_method_unchanged() {
        // Phase 1 must NOT change the existing redact() method signature
        let config = Default::default();
        let engine = RedactionEngine::new(config);
        
        // This should still work exactly as before
        let _result = engine.redact("test AWS key AKIA2E4DAABCDEFG123");
    }

    #[test]
    fn test_engine_default_redaction_config() {
        // Verify default config still works
        let engine = RedactionEngine::new(Default::default());
        let result = engine.redact("test data");
        assert!(!result.redacted.is_empty());
    }
}
