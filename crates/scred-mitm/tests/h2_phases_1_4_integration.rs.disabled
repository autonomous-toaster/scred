/// Integration Tests for HTTP/2 Phases 1-4 (Complete Stack)
/// 
/// Tests the full HTTP/2 implementation from preface through flow control.
/// Validates RFC 7540 and RFC 7541 compliance.

#[cfg(test)]
mod http2_integration_tests {
    use anyhow::Result;
    use tokio::io::{AsyncReadExt, AsyncWriteExt};
    use tokio::net::{TcpListener, TcpStream};
    use std::sync::Arc;

    // Helper: Start a simple H2 server
    async fn start_h2_server(port: u16) -> Result<()> {
        use scred_http::h2::{H2ClientConnection, H2Request, H2Response};

        let listener = TcpListener::bind(format!("127.0.0.1:{}", port)).await?;

        tokio::spawn(async move {
            while let Ok((mut socket, _)) = listener.accept().await {
                let handler = Arc::new(Box::new(|req: H2Request| {
                    Box::pin(async move {
                        Ok(H2Response {
                            stream_id: req.stream_id,
                            status: 200,
                            headers: vec![
                                ("content-type".to_string(), "text/plain".to_string()),
                                ("content-length".to_string(), "13".to_string()),
                            ],
                        })
                    }) as std::pin::Pin<Box<dyn std::future::Future<Output = Result<H2Response>> + Send>>
                }) as Box<dyn Fn(H2Request) -> std::pin::Pin<Box<dyn std::future::Future<Output = Result<H2Response>> + Send>> + Send + Sync>);

                let mut conn = H2ClientConnection::new();
                conn.set_request_handler(handler);

                let _ = conn.handle_connection(&mut socket, 100).await;
            }
        });

        tokio::time::sleep(tokio::time::Duration::from_millis(100)).await;
        Ok(())
    }

    // Helper: Send H2 preface + SETTINGS
    async fn send_h2_preface(stream: &mut TcpStream) -> Result<()> {
        // Send client preface
        stream.write_all(b"PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n").await?;

        // Send SETTINGS frame (type=4, stream=0, no settings)
        let settings_frame = [
            0x00, 0x00, 0x00, // Length: 0
            0x04,             // Type: SETTINGS
            0x00,             // Flags: none
            0x00, 0x00, 0x00, 0x00, // Stream ID: 0
        ];
        stream.write_all(&settings_frame).await?;

        // Read SETTINGS response
        let mut buf = [0u8; 100];
        stream.read(&mut buf).await?;

        Ok(())
    }

    // Helper: Send HEADERS frame
    fn create_headers_frame(stream_id: u32, _method: &str, _path: &str) -> Vec<u8> {
        // Simplified HPACK encoding for GET /
        let mut headers = Vec::new();

        // :method GET (indexed: 2)
        headers.push(0x82);
        // :path / (indexed: 4)
        headers.push(0x84);
        // :scheme https (indexed: 7)
        headers.push(0x87);
        // :authority localhost (literal)
        headers.push(0x41); // Literal indexed, index 1
        let authority = b"localhost";
        headers.push(authority.len() as u8);
        headers.extend_from_slice(authority);

        let mut frame = Vec::new();
        let len = headers.len() as u32;
        frame.push((len >> 16) as u8);
        frame.push((len >> 8) as u8);
        frame.push(len as u8);
        frame.push(0x01); // Type: HEADERS
        frame.push(0x05); // Flags: END_HEADERS | END_STREAM
        frame.push((stream_id >> 24) as u8);
        frame.push((stream_id >> 16) as u8);
        frame.push((stream_id >> 8) as u8);
        frame.push(stream_id as u8);
        frame.extend_from_slice(&headers);

        frame
    }

    // Test 1: Basic Preface Exchange
    #[tokio::test]
    async fn test_preface_exchange() -> Result<()> {
        start_h2_server(8001).await?;

        let mut stream = TcpStream::connect("127.0.0.1:8001").await?;
        send_h2_preface(&mut stream).await?;

        println!("✓ Test 1: Preface exchange - PASS");
        Ok(())
    }

    // Test 2: Frame Parsing
    #[tokio::test]
    async fn test_frame_parsing() -> Result<()> {
        use scred_http::h2::FrameHeader;

        // Create a DATA frame header
        let frame_bytes: &[u8; 9] = &[
            0x00, 0x00, 0x05, // Length: 5
            0x00,             // Type: DATA
            0x00,             // Flags: none
            0x00, 0x00, 0x00, 0x01, // Stream ID: 1
        ];

        let header = FrameHeader::parse(frame_bytes)?;
        assert_eq!(header.length, 5);
        assert_eq!(header.stream_id, 1);

        println!("✓ Test 2: Frame parsing - PASS");
        Ok(())
    }

    // Test 3: HPACK Static Table
    #[tokio::test]
    async fn test_hpack_static_table() -> Result<()> {
        use scred_http::h2::HpackStreamState;

        let state = HpackStreamState::new(1);
        let (name, value) = state.lookup_static_table(2)?;
        assert_eq!(name, ":method");
        assert_eq!(value, "GET");

        let (name, value) = state.lookup_static_table(4)?;
        assert_eq!(name, ":path");
        assert_eq!(value, "/");

        println!("✓ Test 3: HPACK static table - PASS");
        Ok(())
    }

    // Test 4: Flow Control Window
    #[tokio::test]
    async fn test_flow_control_window() -> Result<()> {
        use scred_http::h2::FlowControlWindow;

        let window = FlowControlWindow::new(1000);
        assert_eq!(window.available(), 1000);

        window.consume(300)?;
        assert_eq!(window.available(), 700);

        window.increase(200)?;
        assert_eq!(window.available(), 900);

        // Test overflow protection
        assert!(window.consume(1000).is_err());

        println!("✓ Test 4: Flow control window - PASS");
        Ok(())
    }

    // Test 5: Connection Flow Control
    #[tokio::test]
    async fn test_connection_flow_control() -> Result<()> {
        use scred_http::h2::ConnectionFlowControl;

        let mut fc = ConnectionFlowControl::new(10000);
        assert_eq!(fc.connection_available(), 10000);

        // Create stream window first
        let stream_window = fc.get_or_create_stream(1);
        assert_eq!(stream_window.available(), 10000);

        // Consume data on stream 1
        fc.consume_data(1, 5000)?;
        assert_eq!(stream_window.available(), 5000);
        assert_eq!(fc.connection_available(), 5000);

        // Update stream window (increases it)
        fc.update_stream(1, 3000)?;
        assert_eq!(stream_window.available(), 8000);

        // Connection window unaffected by stream update
        assert_eq!(fc.connection_available(), 5000);

        println!("✓ Test 5: Connection flow control - PASS");
        Ok(())
    }

    // Test 6: Backpressure Detection
    #[tokio::test]
    async fn test_backpressure_detection() -> Result<()> {
        use scred_http::h2::{BackpressureManager, BackpressureConfig};

        let mut bp = BackpressureManager::new(BackpressureConfig {
            max_buffer_size: 1000,
            recovery_threshold: 0.25,
        });

        // Stream 1: Add data below threshold
        assert!(!bp.should_pause(1, 500));
        assert_eq!(bp.buffered_bytes(1), 500);

        // Add more to exceed
        assert!(bp.should_pause(1, 600));
        assert!(bp.is_paused(1));

        // Consume data
        let resume = bp.should_resume(1, 850);
        assert!(resume.is_some());
        assert!(!bp.is_paused(1));

        println!("✓ Test 6: Backpressure detection - PASS");
        Ok(())
    }

    // Test 7: WINDOW_UPDATE Parsing
    #[tokio::test]
    async fn test_window_update_parsing() -> Result<()> {
        use scred_http::h2::{parse_window_update, create_window_update};

        let payload = [0x00, 0x00, 0x27, 0x10]; // 10000
        let (_, increment) = parse_window_update(&payload)?;
        assert_eq!(increment, 10000);

        // Test frame creation
        let frame = create_window_update(1, 5000);
        assert_eq!(frame.len(), 13); // 9 header + 4 payload
        assert_eq!(frame[3], 0x08); // Type: WINDOW_UPDATE

        println!("✓ Test 7: WINDOW_UPDATE parsing - PASS");
        Ok(())
    }

    // Test 8: Pseudo-Header Extraction
    #[tokio::test]
    async fn test_pseudo_headers() -> Result<()> {
        use scred_http::h2::PseudoHeaders;

        let headers = vec![
            (":method".to_string(), "POST".to_string()),
            (":path".to_string(), "/api".to_string()),
            (":authority".to_string(), "example.com".to_string()),
            (":scheme".to_string(), "https".to_string()),
        ];

        let pseudo = PseudoHeaders::from_request_headers(&headers)?;
        assert_eq!(pseudo.method, "POST");
        assert_eq!(pseudo.path, "/api");

        let request_line = pseudo.to_http1_request_line();
        assert_eq!(request_line, "POST /api HTTP/1.1");

        println!("✓ Test 8: Pseudo-header extraction - PASS");
        Ok(())
    }

    // Test 9: Request/Response Builder
    #[tokio::test]
    async fn test_request_response_builder() -> Result<()> {
        use scred_http::h2::{build_h2_request, build_h2_response};

        let headers = vec![
            (":method".to_string(), "GET".to_string()),
            (":path".to_string(), "/".to_string()),
            (":authority".to_string(), "example.com".to_string()),
            (":scheme".to_string(), "https".to_string()),
            ("user-agent".to_string(), "curl".to_string()),
        ];

        let req = build_h2_request(1, headers)?;
        assert_eq!(req.method, "GET");
        assert_eq!(req.path, "/");
        assert_eq!(req.headers.len(), 1);

        let resp_headers = vec![
            (":status".to_string(), "200".to_string()),
            ("content-type".to_string(), "text/plain".to_string()),
        ];
        let resp = build_h2_response(1, 200, resp_headers)?;
        assert_eq!(resp.status, 200);
        assert_eq!(resp.headers.len(), 1);

        println!("✓ Test 9: Request/response builder - PASS");
        Ok(())
    }

    // Test 10: CONTINUATION Frame Handling
    #[tokio::test]
    async fn test_continuation_handling() -> Result<()> {
        use scred_http::h2::ContinuationHandler;

        let mut handler = ContinuationHandler::new();

        // Add initial HEADERS
        handler.add_headers(1, vec![1, 2, 3]);
        assert!(handler.has_pending(1));
        assert_eq!(handler.pending_size(1), 3);

        // Add CONTINUATION
        handler.add_continuation(1, &[4, 5, 6])?;
        assert_eq!(handler.pending_size(1), 6);

        // Get complete
        let block = handler.take_complete_block(1);
        assert!(block.is_some());
        assert_eq!(block.unwrap(), vec![1, 2, 3, 4, 5, 6]);

        println!("✓ Test 10: CONTINUATION handling - PASS");
        Ok(())
    }

    // Test 11: Error Handling - Window Underflow
    #[tokio::test]
    async fn test_error_window_underflow() -> Result<()> {
        use scred_http::h2::FlowControlWindow;

        let window = FlowControlWindow::new(100);
        let result = window.consume(150);
        assert!(result.is_err());
        assert_eq!(window.available(), 100); // unchanged

        println!("✓ Test 11: Error handling (window underflow) - PASS");
        Ok(())
    }

    // Test 12: Error Handling - Invalid WINDOW_UPDATE
    #[tokio::test]
    async fn test_error_invalid_window_update() -> Result<()> {
        use scred_http::h2::parse_window_update;

        let payload = [0x00, 0x00, 0x00, 0x00]; // increment = 0 (invalid)
        let result = parse_window_update(&payload);
        assert!(result.is_err());

        println!("✓ Test 12: Error handling (invalid WINDOW_UPDATE) - PASS");
        Ok(())
    }

