// ============================================================================
// JWT_PATTERNS (1)
// ============================================================================
// Generic JWT detector: eyJ prefix + exactly 2 dots structure
// Covers ALL JWT algorithms (HS256, RS256, EdDSA, etc.)

pub const JWT_PATTERNS = [_]JwtPattern{
    .{ .name = "jwt-generic", .tier = .patterns }, // eyJ + 2 dots = universal JWT
};

