    .{ .name = "gradle-api-key", .pattern = "org\\.gradle\\.caching\\.http\\.authentication.*=\\s*([a-zA-Z0-9_-]{20,})" , .tier = PatternTier.infrastructure }, // Gradle build cache API keys
    // P2 Structured Formats & Automation Patterns (9 new patterns)
