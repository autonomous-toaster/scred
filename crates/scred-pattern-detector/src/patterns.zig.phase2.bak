//! Pattern Definitions
//!
//! Single source of truth for ALL secret patterns:
//! - SIMPLE_PREFIX_PATTERNS (26): Pure prefix, no validation
//! - JWT_PATTERNS (1): eyJ prefix + 2 dots structure
//! - PREFIX_VALIDATION_PATTERNS (45): Prefix + charset/length validation
//! - REGEX_PATTERNS (203): Full regex patterns (198 original + 5 P0 classical secrets)
//!
//! Total: 275 patterns (270 original + 5 P0 additions)

const std = @import("std");

// ============================================================================
// Pattern Tier Definitions (NEW)
// ============================================================================
// Five risk-based tiers for pattern categorization

pub const PatternTier = enum(u8) {
    critical = 0,          // AWS, GitHub, Stripe, Database credentials (24 patterns)
    api_keys = 1,          // Third-party API keys (60+ patterns)
    infrastructure = 2,    // K8s, Docker, Vault, Grafana + REGEX (40+ patterns)
    services = 3,          // Specialty services (100+ patterns)
    patterns = 4,          // Generic regex patterns (50+ patterns)
};

pub fn tierName(tier: PatternTier) []const u8 {
    return switch (tier) {
        .critical => "CRITICAL",
        .api_keys => "API_KEYS",
        .infrastructure => "INFRASTRUCTURE",
        .services => "SERVICES",
        .patterns => "PATTERNS",
    };
}

pub fn tierRiskScore(tier: PatternTier) u8 {
    return switch (tier) {
        .critical => 95,
        .api_keys => 80,
        .infrastructure => 60,
        .services => 40,
        .patterns => 30,
    };
}

pub fn tierDefaultRedact(tier: PatternTier) bool {
    return switch (tier) {
        .critical => true,
        .api_keys => true,
        .infrastructure => false,
        .services => false,
        .patterns => false,
    };
}

// ============================================================================
// Struct Definitions
// ============================================================================

pub const SimplePrefixPattern = struct {
    name: []const u8,
    prefix: []const u8,
    tier: PatternTier,  // NEW: Pattern tier/category
};

pub const JwtPattern = struct {
    name: []const u8,
    tier: PatternTier,  // NEW: Pattern tier/category
    // JWT detection: search for "eyJ" prefix + exactly 2 dots
};

pub const Charset = enum {
    alphanumeric, // a-z, A-Z, 0-9, -, _
    base64, // a-z, A-Z, 0-9, +, /, =
    base64url, // a-z, A-Z, 0-9, -, _, =
    hex, // 0-9, a-f, A-F
    hex_lowercase, // 0-9, a-f
    any, // Non-delimiter characters
};

pub const PrefixValidation = struct {
    name: []const u8,
    prefix: []const u8,
    tier: PatternTier,  // NEW: Pattern tier/category
    min_len: usize, // Minimum token length (0 = no limit)
    max_len: usize, // Maximum token length (0 = no limit)
    charset: Charset, // Character set validation
};

pub const RegexPattern = struct {
    name: []const u8,
    pattern: []const u8, // Raw regex pattern string
    tier: PatternTier,  // NEW: Pattern tier/category
};

