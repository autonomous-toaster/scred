# SCRED Docker Compose Environment Configuration

# ============================================================================
# Fake Upstream Service Configuration
# ============================================================================

FAKE_UPSTREAM_PORT=8001
FAKE_UPSTREAM_IMAGE=python:3.11-slim

# ============================================================================
# httpbin Backend Configuration
# ============================================================================

HTTPBIN_PORT=8000
HTTPBIN_IMAGE=kennethreitz/httpbin:latest
HTTPBIN_WORKERS=1

# ============================================================================
# scred-proxy (Reverse Proxy) Configuration - REQUEST REDACTION
# ============================================================================

# Backend service
SCRED_PROXY_UPSTREAM_URL=http://httpbin:80
SCRED_PROXY_UPSTREAM_TIMEOUT_SECS=30

# Proxy service
SCRED_PROXY_LISTEN_HOST=0.0.0.0
SCRED_PROXY_LISTEN_PORT=9999

# Redaction configuration
# Options: "none" (no redaction), "selective" (smart redaction), "all" (redact everything)
SCRED_PROXY_REDACT_MODE=selective

# Headers to strip/redact (comma-separated)
SCRED_PROXY_REDACT_HEADERS=Authorization,X-API-Key,X-Auth-Token,X-Access-Token

# Enable/disable redaction by location
SCRED_PROXY_REDACT_QUERY_PARAMS=true
SCRED_PROXY_REDACT_BODY=true
SCRED_PROXY_REDACT_REQUEST=true
SCRED_PROXY_REDACT_RESPONSE=false

# Pattern configuration
SCRED_PROXY_PATTERN_ENABLE_AWS=true
SCRED_PROXY_PATTERN_ENABLE_GITHUB=true
SCRED_PROXY_PATTERN_ENABLE_OPENAI=true
SCRED_PROXY_PATTERN_ENABLE_STRIPE=true
SCRED_PROXY_PATTERN_ENABLE_SLACK=true

# Logging
SCRED_PROXY_LOG_LEVEL=debug
SCRED_PROXY_LOG_FORMAT=json

# ============================================================================
# scred-proxy-response-only (Reverse Proxy) Configuration - RESPONSE REDACTION
# ============================================================================

# Backend service (fake-upstream)
SCRED_PROXY_RESPONSE_ONLY_UPSTREAM_URL=http://fake-upstream:8001
SCRED_PROXY_RESPONSE_ONLY_UPSTREAM_TIMEOUT_SECS=30

# Proxy service
SCRED_PROXY_RESPONSE_ONLY_LISTEN_HOST=0.0.0.0
SCRED_PROXY_RESPONSE_ONLY_LISTEN_PORT=9998

# Redaction configuration - RESPONSE ONLY
# Requests pass unmodified to upstream
# Responses from upstream get redacted before returning to client
SCRED_PROXY_RESPONSE_ONLY_REDACT_REQUEST=false
SCRED_PROXY_RESPONSE_ONLY_REDACT_RESPONSE=true

# Pattern configuration
SCRED_PROXY_RESPONSE_ONLY_PATTERN_ENABLE_AWS=true
SCRED_PROXY_RESPONSE_ONLY_PATTERN_ENABLE_GITHUB=true
SCRED_PROXY_RESPONSE_ONLY_PATTERN_ENABLE_OPENAI=true
SCRED_PROXY_RESPONSE_ONLY_PATTERN_ENABLE_STRIPE=true
SCRED_PROXY_RESPONSE_ONLY_PATTERN_ENABLE_SLACK=true

# Logging
SCRED_PROXY_RESPONSE_ONLY_LOG_LEVEL=debug
SCRED_PROXY_RESPONSE_ONLY_LOG_FORMAT=json

# ============================================================================
# scred-mitm (MITM Proxy) Configuration - REQUEST REDACTION
# ============================================================================

# Proxy service
SCRED_MITM_LISTEN_HOST=0.0.0.0
SCRED_MITM_LISTEN_PORT=8888

# Proxy chaining (for corporate environments)
# Leave empty for direct connections
SCRED_MITM_HTTP_PROXY=
SCRED_MITM_HTTPS_PROXY=
SCRED_MITM_NO_PROXY=localhost,127.0.0.1,httpbin,scred-httpbin,*.local

# Redaction configuration
SCRED_MITM_REDACT_RESPONSES=false
SCRED_MITM_REDACT_REQUEST_ONLY=true
SCRED_MITM_ALLOW_ALL_HOSTS=true

# Logging
SCRED_MITM_LOG_LEVEL=debug
SCRED_MITM_LOG_FORMAT=json

# ============================================================================
# scred-mitm-response-only (MITM Proxy) Configuration - RESPONSE REDACTION
# ============================================================================

# Proxy service
SCRED_MITM_RESPONSE_ONLY_LISTEN_HOST=0.0.0.0
SCRED_MITM_RESPONSE_ONLY_LISTEN_PORT=8889

# Proxy chaining
SCRED_MITM_RESPONSE_ONLY_HTTP_PROXY=
SCRED_MITM_RESPONSE_ONLY_HTTPS_PROXY=
SCRED_MITM_RESPONSE_ONLY_NO_PROXY=localhost,127.0.0.1,fake-upstream,*.local

# Redaction configuration - RESPONSE ONLY
# Requests forwarded unmodified to upstream
# Responses from upstream get redacted before returning to client
SCRED_MITM_RESPONSE_ONLY_REDACT_REQUESTS=false
SCRED_MITM_RESPONSE_ONLY_REDACT_RESPONSES=true
SCRED_MITM_RESPONSE_ONLY_ALLOW_ALL_HOSTS=true

# Logging
SCRED_MITM_RESPONSE_ONLY_LOG_LEVEL=debug
SCRED_MITM_RESPONSE_ONLY_LOG_FORMAT=json

# ============================================================================
# Docker Compose Configuration
# ============================================================================

# Compose project name (affects container names)
COMPOSE_PROJECT_NAME=scred

# Network configuration
COMPOSE_DOCKER_CLI_BUILD=1
BUILDKIT_PROGRESS=plain

# ============================================================================
# Testing Configuration
# ============================================================================

# Test client configuration
TEST_BACKEND_URL=http://localhost:8000
TEST_PROXY_URL=http://localhost:9999
TEST_PROXY_RESPONSE_ONLY_URL=http://localhost:9998
TEST_MITM_PROXY=http://scred-mitm:8888
TEST_MITM_RESPONSE_ONLY_PROXY=http://scred-mitm-response-only:8889
TEST_FAKE_UPSTREAM_URL=http://localhost:8001

# Test secrets (from secrets.json)
TEST_AWS_KEY=AKIAIOSFODNN7EXAMPLE
TEST_AWS_SECRET=wJalrXUtnFEMI/K7MDENG+bPxRfiCYEXAMPLEKEY

# Test GitHub token pattern
TEST_GITHUB_TOKEN=ghp_1234567890abcdefghijklmnopqrstuvwxyzABCDEF

# Test OpenAI key pattern
TEST_OPENAI_KEY=sk-1234567890abcdefghijklmnopqrstuvwxyz

# Test Stripe key pattern
TEST_STRIPE_KEY=sk_live_1234567890abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOP

# Test database credentials
TEST_DB_PASSWORD=super_secret_postgres_password_123!@#
TEST_MONGODB_URI=mongodb+srv://admin:password123@cluster0.mongodb.net/dbname?retryWrites=true

# ============================================================================
# Advanced Configuration
# ============================================================================

# Character preservation (should always be true)
SCRED_CHARACTER_PRESERVE=true

# Redaction character (what to replace secrets with)
SCRED_REDACTION_CHAR=x

# Redaction pattern: "full" (replace entire secret) or "partial" (keep prefix)
SCRED_REDACTION_PATTERN=full

# Max request body size (bytes)
SCRED_MAX_BODY_SIZE=10485760  # 10MB

# Connection timeout (seconds)
SCRED_CONNECTION_TIMEOUT=30

# Request timeout (seconds)
SCRED_REQUEST_TIMEOUT=60

# ============================================================================
# Performance Configuration
# ============================================================================

# Thread pool size (for multi-threaded execution)
SCRED_THREAD_POOL_SIZE=4

# Buffer size (bytes)
SCRED_BUFFER_SIZE=65536

# Cache size (patterns/certificates)
SCRED_CACHE_SIZE=1000

# ============================================================================
# Security Configuration
# ============================================================================

# TLS certificate directory (mounted volume)
SCRED_CERT_DIR=/scred-certs
SCRED_CERT_DIR_RESPONSE_ONLY=/scred-certs-response-only

# TLS certificate TTL (seconds, 24 hours)
SCRED_CERT_TTL=86400

# Allow self-signed certificates
SCRED_ALLOW_SELF_SIGNED=true

# ============================================================================
# Notes
# ============================================================================

# REDACTION MODES:
#
# 1. REQUEST-ONLY (scred-proxy, scred-mitm):
#    - REDACT_REQUEST=true, REDACT_RESPONSE=false
#    - Requests to upstream are redacted (hide secrets from backend)
#    - Responses from upstream pass through unmodified
#    - Use case: Protect backend from seeing client secrets
#
# 2. RESPONSE-ONLY (scred-proxy-response-only, scred-mitm-response-only):
#    - REDACT_REQUEST=false, REDACT_RESPONSE=true
#    - Requests to upstream pass through unmodified
#    - Responses from upstream are redacted (hide secrets from client)
#    - Use case: Protect client from seeing upstream's exposed secrets
#
# 3. BOTH (configurable):
#    - REDACT_REQUEST=true, REDACT_RESPONSE=true
#    - Both requests and responses redacted (maximum protection)
#    - Use case: Untrusted network or adversarial scenarios

# TEST PATTERNS in secrets.json:
# - AWS IAM keys (AKIA prefix)
# - API tokens (sk- prefix)
# - GitHub tokens (ghp_, ghu_, glpat- prefixes)
# - Database credentials (password fields)
# - JWT/OAuth tokens
# - Private keys (BEGIN RSA/EC/OPENSSH PRIVATE KEY)
# - GCP/Firebase service accounts
# - Stripe live keys (sk_live_ prefix)
# - Multiple secrets in single values
# - Base64-encoded secrets
# - Secrets in URL parameters
# - Secrets in JSON object values
